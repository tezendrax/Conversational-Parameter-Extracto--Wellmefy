# CPE Engine Configuration

# Host and Port for FastAPI
CPE_HOST=127.0.0.1
CPE_PORT=8000

# Whisper Configuration
# Available model sizes: tiny, base, small, medium, large-v3.
# Recommended for local CPU: tiny or base. For GPU/high performance: large-v3.
WHISPER_MODEL_SIZE=tiny
WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=float16 # Change to float16 if running on CUDA

# LLM Provider Configuration
# Set LLM_PROVIDER to "openai_compatible" (for Ollama, LLaMA.cpp, Groq, GitHub Models API) or "mock" (for offline/dry-run mode).
LLM_PROVIDER=mock
LLM_MODEL=llama3-8b
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=your_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///cpe_database.sqlite

# Cache Duration in hours (for cleaning up raw transcripts)
CACHE_DURATION_HOURS=24
